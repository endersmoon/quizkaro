{
  "name": "quizkaro",
  "version": "1.0.0",
  "description": "Template-based quiz video generator powered by Revideo",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "render": "tsx src/cli.ts",
    "render:old": "tsx src/render.ts",
    "serve": "npx revideo serve --projectFile ./src/project.ts",
    "web": "tsx src/web/server.ts"
  },
  "dependencies": {
    "@hono/node-server": "^1.19.11",
    "@reelgen/2d": "0.10.4",
    "@reelgen/core": "0.10.4",
    "@reelgen/ffmpeg": "0.10.4",
    "@reelgen/renderer": "0.10.4",
    "@reelgen/telemetry": "0.10.4",
    "@reelgen/ui": "0.10.4",
    "@reelgen/vite-plugin": "0.10.4",
    "hono": "^4.12.8"
  },
  "devDependencies": {
    "@types/node": "^25.5.0",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "vite": "^6.4.1"
  }
}
